# ─────────────────────────────────────────────────────────────────────────────
# ATY Digital Store — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://atydigitalstore.com

# Amazon Associates tracking tag
NEXT_PUBLIC_AMAZON_TAG=atydigital-20

# Newsletter provider API key (e.g. Resend, ConvertKit, Mailchimp)
NEWSLETTER_API_KEY=your_api_key_here
NEWSLETTER_LIST_ID=your_list_id_here

# Analytics (optional — use Plausible, Umami, or Vercel Analytics)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=atydigitalstore.com

# Contact form handler (e.g. Resend)
RESEND_API_KEY=your_resend_key_here
CONTACT_EMAIL_TO=hello@atydigitalstore.com
